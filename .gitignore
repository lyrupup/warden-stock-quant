# ---------------------------------------------------------------------------
# 守望者量化交易系统 · 根目录 .gitignore（monorepo 统一规则）
# ---------------------------------------------------------------------------

# 系统与编辑器
.DS_Store
*.local
*.log

# 环境变量（示例文件可提交）
.env
.env.*
!.env.example
!**/.env.example

# ---------------------------------------------------------------------------
# Python / 后端（backend/）
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# PostgreSQL bind mount 数据目录（禁止提交）
backend/deploy/pgdata/

# 列存派生数据（M2+）
backend/data/parquet/

# ---------------------------------------------------------------------------
# Node / 前端（frontend/）
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
.eslintcache
coverage/
