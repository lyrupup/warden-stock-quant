APP_ENV=dev
API_PORT=8000

# ===== 安全 =====
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=604800
# 用于对称加密 warden-stock-data 的 secretKey（M2+ 使用）
CONFIG_ENC_KEY=please-change-me-32bytes-key

# ===== PostgreSQL =====
# 宿主端口错开 warden-stock-data（5432/6379）；Docker 部署时 PG_HOST/PG_PORT 由 compose 覆盖为 postgres:5432
PG_HOST=localhost
PG_PORT=5433
PG_USER=warden
PG_PASSWORD=warden
PG_DB=warden_quant

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6380

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ===== warden-stock-data 数据源（M2+；亦可走 DB 凭证表，优先 DB） =====
DATA_BASE_URL=http://localhost:8080
DATA_SECRET_ID=
DATA_SECRET_KEY=

# ===== 回测/任务配额默认（可被 plan 覆盖） =====
MAX_CONCURRENT_BACKTESTS=2
MAX_UNIVERSE=500
MAX_RANGE_DAYS=2520

# ===== 实盘（默认关闭；自托管启用） =====
LIVE_ENABLED=false

# ===== 登录失败限速（M1） =====
LOGIN_FAIL_MAX=5
LOGIN_FAIL_WINDOW=300
